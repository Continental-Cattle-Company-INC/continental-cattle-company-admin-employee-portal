{
  "name": "WeeklyPlaybook",
  "type": "object",
  "properties": {
    "week_of": {
      "type": "string",
      "format": "date"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional description or summary of this week's playbook (up to 1000 characters)"
    },
    "buy_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sell_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "feed_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "avoid_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hedge_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "watch_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "market_summary": {
      "type": "string"
    },
    "risk_score": {
      "type": "number",
      "description": "0-100"
    },
    "opportunity_score": {
      "type": "number",
      "description": "0-100"
    }
  },
  "required": [
    "week_of"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": {
          "$in": [
            "admin",
            "manager",
            "market_admin"
          ]
        }
      }
    },
    "read": {
      "user_condition": {
        "role": {
          "$in": [
            "admin",
            "manager",
            "market_admin",
            "user"
          ]
        }
      }
    },
    "update": {
      "user_condition": {
        "role": {
          "$in": [
            "admin",
            "manager",
            "market_admin"
          ]
        }
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}